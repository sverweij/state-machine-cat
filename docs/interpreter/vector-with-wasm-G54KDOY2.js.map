function decode(s: string): Uint8Array {
    const out = new Uint8Array(593013);
    let pos = 0, b = 0, n = 0, v = -1;

    for (let i = 0, len = s.length; i < len; i++) {
        const c = s.charCodeAt(i);
        if (c > 127) continue;
        const p = D[c];
        if (p < 0) continue;
        if (v < 0) {
            v = p;
        } else {
            v += p * 91;
            b |= v << n;
            n += (v & 8191) > 88 ? 13 : 14;
            do {
                out[pos++] = b;
                b >>>= 8;
                n -= 8;
            } while (n > 7);
            v = -1;
        }
    }

    if (v >= 0) out[pos++] = (b | v << n) & 0xff;

    return out;
}

